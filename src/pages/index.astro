---
import Header from "../components/Header.astro";
import ProductMenu from "../components/ProductMenu.astro";
import ContactForm from "../components/ContactForm.astro";
import Footer from "../components/Footer.astro";
import CartDrawer from "../components/CartDrawer.svelte";
import CartToast from "../components/CartToast.svelte";
import { products } from "../data/products";
import "../styles/global.css";
---

<!doctype html>
<html lang="es">
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width, initial-scale=1.0" />
		<meta
			name="description"
			content="Chaud & Glace - Heladería y cafetería donde el sabor y la calidez existen en un mismo lugar. Ubicados en Calle 3 poniente y Av. Revolución #202"
		/>
		<meta
			name="keywords"
			content="heladería, cafetería, frappes, crepas, helados artesanales, postres"
		/>
		<title>Chaud & Glace - Cafe con encanto</title>
		
		<!-- Favicons para mejor visibilidad -->
		<link rel="icon" type="image/png" sizes="32x32" href="/logo/LogoIcon.png" />
		<link rel="icon" type="image/png" sizes="16x16" href="/logo/LogoIcon.png" />
		<link rel="apple-touch-icon" sizes="180x180" href="/logo/LogoIcon.png" />
		<link rel="shortcut icon" href="/logo/LogoIcon.png" />

		<!-- Google Fonts -->
		<link rel="preconnect" href="https://fonts.googleapis.com" />
		<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
		<link
			href="https://fonts.googleapis.com/css2?family=Outfit:wght@300;400;500;600;700;800&display=swap"
			rel="stylesheet"
		/>
	</head>
	<body class="font-['Outfit',sans-serif] antialiased">
		<Header />

		<!-- Hero Section -->
		<section
			id="inicio"
			class="relative min-h-screen flex items-center justify-center overflow-hidden pt-16 sm:pt-20"
		>
			<!-- Background Image -->
			<div class="absolute inset-0 z-0">
				<img
					src="/hero-background.png"
					alt="Chaud & Glace Background"
					class="w-full h-full object-cover"
				/>
				<div
					class="absolute inset-0 bg-linear-to-br from-black/60 via-black/40 to-chaud-900/60"
				>
				</div>
			</div>

			<!-- Hero Content -->
			<div
				class="relative z-10 container mx-auto px-4 sm:px-6 text-center text-white"
			>
				<h1 class="text-4xl sm:text-5xl md:text-6xl lg:text-7xl font-bold mb-4 sm:mb-6 animate-fade-in px-2">
					Bienvenidos a<br />
					<span
						class="text-transparent bg-clip-text bg-linear-to-r from-chaud-300 to-chaud-500"
					>
						Chaud & Glace
					</span>
				</h1>
				<p
					class="text-lg sm:text-xl md:text-2xl mb-6 sm:mb-8 text-white max-w-2xl mx-auto px-4"
				>
					Donde el sabor y la calidez existen en un mismo lugar
				</p>
				<div class="flex flex-col sm:flex-row gap-3 sm:gap-4 justify-center px-4">
					<a
						href="#menu"
						class="bg-linear-to-r from-chaud-500 to-chaud-600 text-white px-6 sm:px-8 py-3 sm:py-4 rounded-full font-bold text-base sm:text-lg hover:shadow-2xl hover:scale-105 transition-all duration-300"
					>
						Ver Menú
					</a>
					<a
						href="#contacto"
						class="bg-white/20 backdrop-blur-md text-white px-6 sm:px-8 py-3 sm:py-4 rounded-full font-bold text-base sm:text-lg border-2 border-white/50 hover:bg-white/30 hover:scale-105 transition-all duration-300"
					>
						Contáctanos
					</a>
				</div>
			</div>

			<!-- Scroll Indicator -->
			<div
				class="absolute bottom-8 left-1/2 transform -translate-x-1/2 z-10 animate-bounce"
			>
				<svg
					class="w-6 h-6 text-white"
					fill="none"
					stroke="currentColor"
					viewBox="0 0 24 24"
				>
					<path
						stroke-linecap="round"
						stroke-linejoin="round"
						stroke-width="2"
						d="M19 14l-7 7m0 0l-7-7m7 7V3"></path>
				</svg>
			</div>
		</section>

		<!-- About Section -->
		<section id="sobre-nosotros" class="py-12 sm:py-16 md:py-20 bg-white">
			<div class="container mx-auto px-4 sm:px-6">
				<div class="max-w-6xl mx-auto">
					<div class="text-center mb-8 sm:mb-10 md:mb-12">
						<h2
							class="text-3xl sm:text-4xl md:text-5xl font-bold text-warm-900 mb-4 sm:mb-6 px-4"
						>
							Sobre Nosotros
						</h2>
						<div
							class="w-20 sm:w-24 h-1 bg-linear-to-r from-chaud-500 to-chaud-600 mx-auto mb-6 sm:mb-8"
						>
						</div>
					</div>

					<div
						class="grid grid-cols-1 md:grid-cols-2 gap-8 sm:gap-10 md:gap-12 items-center"
					>
						<div class="space-y-4 sm:space-y-6">
							<p class="text-base sm:text-lg text-gray-700 leading-relaxed px-2">
								<span class="text-xl sm:text-2xl font-bold text-chaud-700"
									>Chaud & Glace</span
								>
								es una heladería y cafetería donde el sabor y calidez
								existen en un mismo lugar.
							</p>
							<p class="text-sm sm:text-base text-gray-600 leading-relaxed px-2">
								Nos especializamos en crear experiencias únicas
								para nuestros clientes, ofreciendo productos
								frescos hechos al momento con los mejores
								ingredientes. Desde nuestros deliciosos frappes
								hasta nuestras crepas artesanales, cada producto
								está hecho con amor y dedicación.
							</p>
							<p class="text-sm sm:text-base text-gray-600 leading-relaxed px-2">
								Ven y descubre por qué somos el lugar favorito
								de la comunidad para disfrutar de un momento
								dulce y especial.
							</p>

							<div class="grid grid-cols-3 gap-3 sm:gap-4 pt-4 sm:pt-6 px-2">
								<div class="text-center">
									<div
										class="text-3xl font-bold text-chaud-700 mb-2"
									>
										100%
									</div>
									<div class="text-sm text-gray-600">
										Artesanal
									</div>
								</div>
								<div class="text-center">
									<div
										class="text-3xl font-bold text-chaud-700 mb-2"
									>
										Fresh
									</div>
									<div class="text-sm text-gray-600">
										Ingredientes
									</div>
								</div>
								<div class="text-center">
									<div
										class="text-3xl font-bold text-chaud-700 mb-2"
									>
										❤️
									</div>
									<div class="text-sm text-gray-600">
										Hecho con Amor
									</div>
								</div>
							</div>
						</div>

						<div class="relative">
							<div
								class="aspect-square rounded-2xl overflow-hidden shadow-2xl"
							>
								<img
									src="/about-image.jpeg"
									alt="Chaud & Glace Interior"
									class="w-full h-full object-cover"
								/>
							</div>
							<div
								class="absolute -bottom-4 -right-4 sm:-bottom-6 sm:-right-6 bg-linear-to-br from-chaud-500 to-chaud-600 text-white p-4 sm:p-6 rounded-xl sm:rounded-2xl shadow-xl"
							>
								<div class="text-2xl sm:text-3xl font-bold">2+</div>
								<div class="text-xs sm:text-sm whitespace-nowrap">Años de experiencia</div>
							</div>
						</div>
					</div>
				</div>
			</div>
		</section>

		<!-- Products Menu -->
		<ProductMenu products={products} />

		<!-- Contact Form -->
		<ContactForm />

		<!-- Footer -->
		<Footer />

		<!-- Cart System -->
		<CartDrawer client:load />
		<CartToast client:load />

		<style>
			@keyframes fade-in {
				from {
					opacity: 0;
					transform: translateY(20px);
				}
				to {
					opacity: 1;
					transform: translateY(0);
				}
			}

			.animate-fade-in {
				animation: fade-in 1s ease-out;
			}

			html {
				scroll-behavior: smooth;
			}
		</style>
	</body>
</html>
