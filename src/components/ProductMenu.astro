---
import AddToCartButton from './AddToCartButton.svelte';
import type { Product } from '../data/products';
import { getCloudinaryUrl, getResponsiveSrcSet } from '../lib/cloudinary';

interface Props {
  products: Product[];
  googleDriveLink?: string;
}

const { products, googleDriveLink } = Astro.props;

// Filter breakfast special and featured products
const breakfastSpecials = products.filter(p => p.breakfastSpecial);
const featuredProducts = products.filter(p => p.featured);

// Generate Product schema markup for all featured products
const productSchemas = featuredProducts.map(product => ({
  "@type": "Product",
  "@id": `https://chaudglace.com/#product-${product.id}`,
  "name": product.name,
  "description": product.description,
  "image": getCloudinaryUrl(product.image, { width: 600 }),
  "brand": {
    "@type": "Brand",
    "name": "Chaud & Glace"
  },
  "offers": {
    "@type": "Offer",
    "url": "https://chaudglace.com/#menu",
    "priceCurrency": "MXN",
    "price": product.numericPrice?.toString() || "0",
    "availability": "https://schema.org/InStock"
  },
  "aggregateRating": {
    "@type": "AggregateRating",
    "ratingValue": "4.8",
    "reviewCount": "1"
  }
}));
---

<section id="menu" class="py-12 sm:py-16 md:py-20 lg:py-24 bg-white">
  <div class="container mx-auto px-4 sm:px-6 lg:px-8">
    
    <!-- JSON-LD Product Schema Markup -->
    <script type="application/ld+json" set:html={JSON.stringify({
      "@context": "https://schema.org",
      "@type": "ItemList",
      "name": "Productos Destacados - Chaud & Glace",
      "description": "Helados artesanales, frappes y especialidades de Chaud & Glace en Ciudad Serdán, Puebla",
      "itemListElement": productSchemas
    })} />
    
    <!-- Breakfast Special Section -->
    {breakfastSpecials.length > 0 && (
      <div id="desayunos" class="mb-12 sm:mb-16 md:mb-24">
        <div class="text-center mb-10 sm:mb-12 md:mb-16">
          <div class="inline-block px-4 py-2 sm:px-6 sm:py-3 bg-linear-to-r from-orange-100 to-yellow-100 rounded-full mb-4">
            <span class="text-orange-900 font-bold text-sm sm:text-base">☀️ Desayunos Sorpresa</span>
          </div>
          <h2 class="text-3xl sm:text-4xl md:text-5xl font-bold text-warm-900 mb-2 sm:mb-3 px-4">
            Desayunos Sorpresa en Ciudad Serdán
          </h2>
          <p class="text-warm-600 text-base sm:text-lg max-w-2xl mx-auto leading-relaxed px-4">
            Prueba nuestros deliciosos desayunos sorpresa artesanales preparados cada mañana. Disponibles de 7:00 AM a 11:00 AM, perfectos para comenzar tu día en Ciudad Serdán con sabor y encanto
          </p>
        </div>

        <!-- Breakfast Grid -->
        <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-4 sm:gap-6 lg:gap-8 mb-8 sm:mb-10">
          {breakfastSpecials.map((product) => (
            <div 
              class="breakfast-card flex flex-col bg-linear-to-br from-orange-50 to-yellow-50 rounded-2xl sm:rounded-3xl shadow-md overflow-hidden hover:shadow-xl transition-all duration-500 hover:-translate-y-2 group border-2 border-orange-200 hover:border-orange-400"
            >
              <!-- Product Image -->
              <div class="relative overflow-hidden aspect-square sm:aspect-video lg:aspect-square bg-white">
                <img 
                  src={getCloudinaryUrl(product.image, { width: 400 })}
                  srcset={getResponsiveSrcSet(product.image, [320, 400, 640])}
                  sizes="(max-width: 640px) 320px, (max-width: 1024px) 400px, 640px"
                  alt={`${product.name} - Desayuno sorpresa artesanal en Ciudad Serdán, Puebla`}
                  class="w-full h-full object-contain p-2 group-hover:scale-105 transition-transform duration-700"
                  loading="lazy"
                  decoding="async"
                />
                
                <!-- Breakfast Badge -->
                <div class="absolute top-2 right-2 sm:top-4 sm:right-4 bg-linear-to-r from-orange-500 to-yellow-500 text-white px-2.5 py-1.5 sm:px-4 sm:py-2 rounded-full font-bold shadow-lg backdrop-blur-sm z-10 flex items-center gap-1.5">
                  <span class="text-lg sm:text-xl">🌟</span>
                  <span class="text-xs sm:text-sm font-semibold">Sorpresa</span>
                </div>
              </div>
            </div>
          ))}
        </div>

        <!-- Breakfast CTA -->
        <div class="bg-linear-to-r from-orange-100 to-yellow-50 rounded-2xl sm:rounded-3xl p-6 sm:p-8 border-2 border-orange-200 mb-12 sm:mb-16 md:mb-20">
          <p class="text-center text-warm-700 text-base sm:text-lg font-semibold">
            ⏰ Los desayunos sorpresa están disponibles de lunes a domingo de <span class="text-orange-600 font-bold">7:00 AM a 11:00 AM</span>
          </p>
        </div>

        <!-- Separator -->
        <div class="my-12 sm:my-16 md:my-20">
          <div class="flex items-center gap-4">
            <div class="flex-1 h-px bg-linear-to-r from-transparent to-chaud-200"></div>
            <span class="text-warm-500 text-sm font-semibold px-4">MÁS FAVORITOS</span>
            <div class="flex-1 h-px bg-linear-to-l from-transparent to-chaud-200"></div>
          </div>
        </div>
      </div>
    )}

    <!-- Section Header -->
    <div class="text-center mb-12 sm:mb-16 md:mb-20">
      <span class="inline-block px-3 py-1.5 sm:px-4 sm:py-2 bg-linear-to-r from-chaud-100 to-chaud-200 text-chaud-700 rounded-full text-xs sm:text-sm font-semibold mb-3 sm:mb-4">
        ✨ Lo Mejor de Nosotros
      </span>
      <h2 class="text-3xl sm:text-4xl md:text-5xl font-bold text-warm-900 mb-3 sm:mb-4 px-4">
        Helados Artesanales Recomendados
      </h2>
      <p class="text-warm-600 text-base sm:text-lg max-w-2xl mx-auto leading-relaxed px-4">
        Los favoritos de nuestros clientes en Ciudad Serdán. Helados artesanales, frappes caseros y especialidades de cafetería, seleccionados para ofrecerte la mejor experiencia en cada visita
      </p>
    </div>

    <!-- Featured Products Grid -->
    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-4 sm:gap-6 lg:gap-8 mb-12 sm:mb-16 md:mb-20">
      {featuredProducts.map((product) => (
        <div 
          class="featured-card flex flex-col bg-linear-to-br from-white to-chaud-50 rounded-2xl sm:rounded-3xl shadow-lg overflow-hidden hover:shadow-2xl transition-all duration-500 hover:-translate-y-2 group border border-chaud-200 hover:border-chaud-400"
        >
          <!-- Product Image with Badge -->
          <div class="relative overflow-hidden aspect-4/3 sm:aspect-square lg:aspect-4/3 bg-white">
            <img 
              src={getCloudinaryUrl(product.image, { width: 400 })}
              srcset={getResponsiveSrcSet(product.image, [320, 400, 640])}
              sizes="(max-width: 640px) 320px, (max-width: 1024px) 400px, 640px"
              alt={`${product.name} - Helado artesanal en Ciudad Serdán, Puebla - Chaud & Glace`}
              class="w-full h-full object-contain p-2 group-hover:scale-105 transition-transform duration-700"
              loading="lazy"
              decoding="async"
            />
            
            <!-- Featured Badge -->
            <div class="absolute top-2 right-2 sm:top-4 sm:right-4 bg-linear-to-r from-chaud-600 to-chaud-700 text-white px-2.5 py-1.5 sm:px-4 sm:py-2 rounded-full font-bold shadow-xl backdrop-blur-sm z-10 flex items-center gap-1.5">
              <span class="text-lg sm:text-xl">⭐</span>
              <span class="text-xs sm:text-sm font-semibold">Destacado</span>
            </div>
            
            <!-- Price Badge -->
            <div class="absolute bottom-2 left-2 sm:bottom-4 sm:left-4 bg-white text-chaud-600 px-3 py-2 sm:px-5 sm:py-2.5 rounded-full font-bold shadow-lg z-10 border border-chaud-200">
              {product.price}
            </div>
          </div>
          
          <!-- Product Info -->
          <div class="p-4 sm:p-5 lg:p-6 grow flex flex-col">
            <h3 class="text-lg sm:text-xl lg:text-2xl font-bold text-warm-900 mb-2 sm:mb-3 leading-tight">
              {product.name}
            </h3>
            
            <p class="text-sm sm:text-base text-warm-600 mb-4 sm:mb-5 leading-relaxed line-clamp-2">
              {product.description}
            </p>
            
            {product.ingredients && (
              <div class="mb-4 p-2.5 sm:p-3 bg-chaud-50 rounded-lg border border-chaud-100">
                <span class="text-xs sm:text-sm font-bold text-chaud-700 block mb-1">
                  Ingredientes:
                </span>
                <p class="text-xs sm:text-sm text-warm-700 leading-relaxed line-clamp-1">
                  {product.ingredients}
                </p>
              </div>
            )}
            
            {product.size && (
              <div class="mb-4 sm:mb-5">
                <span class="inline-flex items-center gap-1.5 sm:gap-2 text-xs sm:text-sm font-semibold text-chaud-600 bg-chaud-50 px-2.5 py-1.5 sm:px-3 rounded-full border border-chaud-200">
                  <svg class="w-3.5 h-3.5 sm:w-4 sm:h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M7 21a4 4 0 01-4-4V5a2 2 0 012 2h4a2 2 0 012 2v12a4 4 0 01-4 4zm0 0h12a2 2 0 002-2v-4a2 2 0 00-2-2h-2.343M11 7.343l1.657-1.657a2 2 0 012.828 0l2.829 2.829a2 2 0 010 2.828l-8.486 8.485M7 17h.01"></path>
                  </svg>
                  {product.size}
                </span>
              </div>
            )}
            
            <div class="mt-auto">
              <AddToCartButton
                client:idle
                id={product.id}
                name={product.name}
                price={product.numericPrice}
                image={product.image}
                size={product.size}
              />
            </div>
          </div>
        </div>
      ))}
    </div>

    <!-- CTA Section to Full Menu -->
    <div class="bg-linear-to-r from-chaud-50 to-chaud-100 rounded-2xl sm:rounded-3xl p-8 sm:p-10 lg:p-12 border-2 border-chaud-200 hover:border-chaud-400 transition-all duration-300">
      <div class="max-w-3xl mx-auto text-center">
        <h3 class="text-2xl sm:text-3xl md:text-4xl font-bold text-warm-900 mb-3 sm:mb-4">
          Menú Completo: 70+ Productos
        </h3>
        <p class="text-warm-600 text-base sm:text-lg mb-6 sm:mb-8 leading-relaxed">
          Descarga nuestro menú PDF con más de 70 productos artesanales: helados gourmet, frappes especiales, crepas dulces, bebidas frías y calientes. Todo lo que Chaud & Glace en Ciudad Serdán, Puebla tiene para ofrecerte.
        </p>
        
        <div class="flex flex-col sm:flex-row gap-3 sm:gap-4 justify-center flex-wrap">
          {googleDriveLink && (
            <a 
              href={googleDriveLink}
              target="_blank"
              rel="noopener noreferrer"
              class="inline-flex items-center justify-center gap-2 px-6 sm:px-8 py-3 sm:py-4 bg-chaud-600 text-white rounded-full font-bold text-base sm:text-lg hover:bg-chaud-700 hover:shadow-lg transition-all duration-300 hover:scale-105"
            >
              <svg class="w-5 h-5 sm:w-6 sm:h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 16v-4m0 0V8m0 4h4m-4 0H8"></path>
              </svg>
              Ver Menú
            </a>
          )}
        </div>
      </div>
    </div>
  </div>
</section>

<style>
  .line-clamp-1 {
    display: -webkit-box;
    -webkit-line-clamp: 1;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }

  .line-clamp-2 {
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }
</style>
