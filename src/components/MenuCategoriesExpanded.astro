---
import type { Product } from '../data/products';
import { getCloudinaryUrl, getResponsiveSrcSet } from '../lib/cloudinary';
import AddToCartButton from './AddToCartButton.svelte';

interface Props {
  products: Product[];
}

const { products } = Astro.props;

// Group products by category
const categories = {
  "Heladería": {
    description: "Nuestros helados artesanales son la estrella de Chaud & Glace. Elaborados con ingredientes premium, técnicas artesanales y sin conservantes. Cada bola de helado gourmet es una experiencia única de sabor y cremosidad.",
    emoji: "🍦",
    keywords: "helados artesanales, helados gourmet, helados caseros, helados en Puebla"
  },
  "Bebidas": {
    description: "Bebidas frías y calientes pensadas para refrescar y deleitar. Desde frappes caseros con ingredientes frescos, hasta café gourmet y bebidas especiales. Cada trago es un viaje de sabor.",
    emoji: "☕",
    keywords: "frappes caseros, bebidas frías, café gourmet, bebidas especiales"
  },
  "Reposteria y Snacks": {
    description: "Repostería artesanal y snacks frescos preparados diariamente. Crepas dulces, pasteles gourmet, croissants, y más. Todos nuestros productos se hacen con los mejores ingredientes sin conservantes artificiales.",
    emoji: "🍰",
    keywords: "crepas dulces, repostería artesanal, pasteles gourmet, postres frescos"
  },
  "Salados": {
    description: "Opciones saladas para complementar tu visita. Desde sándwiches artesanales hasta opciones ligeras. Perfectos para cualquier hora del día en Ciudad Serdán.",
    emoji: "🥪",
    keywords: "sándwiches artesanales, opciones saladas, comida fresca"
  },
  "Completos": {
    description: "Nuestras creaciones más elaboradas y especiales. Combinaciones únicas que reflejan nuestro compromiso con la calidad y la innovación en cada plato.",
    emoji: "✨",
    keywords: "platos especiales, creaciones gourmet, especialidades de la casa"
  }
};

type CategoryKey = keyof typeof categories;

const groupedProducts = products.reduce((acc: Record<CategoryKey, Product[]>, product) => {
  const category = product.category as CategoryKey;
  if (!acc[category]) {
    acc[category] = [];
  }
  acc[category].push(product);
  return acc;
}, {} as Record<CategoryKey, Product[]>);
---

<section id="menu" class="py-12 sm:py-16 md:py-20 lg:py-24 bg-linear-to-br from-white via-chaud-50 to-white">
  <div class="container mx-auto px-4 sm:px-6 lg:px-8">
    
    <!-- Section Header with SEO -->
    <div class="text-center mb-16 sm:mb-20 md:mb-24 max-w-4xl mx-auto">
      <div class="inline-block px-4 py-2 sm:px-6 sm:py-3 bg-linear-to-r from-chaud-100 to-chaud-200 rounded-full mb-4 sm:mb-6">
        <span class="text-chaud-700 font-bold text-sm sm:text-base">🍓 Menú Completo de Chaud & Glace</span>
      </div>
      
      <h2 class="text-3xl sm:text-4xl md:text-5xl lg:text-6xl font-bold text-warm-900 mb-4 sm:mb-6 px-4 leading-tight">
        Helados Artesanales y Café Gourmet en Puebla
      </h2>
      
      <p class="text-warm-600 text-base sm:text-lg md:text-xl max-w-3xl mx-auto leading-relaxed px-4 mb-4 sm:mb-6">
        Descubre nuestro menú completo: helados artesanales gourmet, frappes especiales, crepas dulces, bebidas frías y calientes, repostería fresca y desayunos sorpresa. Todos nuestros productos se elaboran con ingredientes premium en Ciudad Serdán, Puebla.
      </p>
      
      <div class="flex flex-col sm:flex-row gap-3 sm:gap-4 justify-center flex-wrap">
        <div class="inline-flex items-center gap-2 text-chaud-600 font-semibold text-sm sm:text-base">
          <svg class="w-5 h-5 text-green-500" fill="currentColor" viewBox="0 0 20 20">
            <path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"></path>
          </svg>
          100% Artesanal
        </div>
        <div class="inline-flex items-center gap-2 text-chaud-600 font-semibold text-sm sm:text-base">
          <svg class="w-5 h-5 text-green-500" fill="currentColor" viewBox="0 0 20 20">
            <path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"></path>
          </svg>
          Ingredientes Premium
        </div>
        <div class="inline-flex items-center gap-2 text-chaud-600 font-semibold text-sm sm:text-base">
          <svg class="w-5 h-5 text-green-500" fill="currentColor" viewBox="0 0 20 20">
            <path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"></path>
          </svg>
          Sin Conservantes
        </div>
      </div>
    </div>

    <!-- Categories Grid -->
    {Object.entries(groupedProducts).map(([categoryName, categoryProducts]) => {
      const category = categories[categoryName as CategoryKey];
      if (!category) return null;

      return (
        <div class="mb-16 sm:mb-20 md:mb-24">
          <!-- Category Header -->
          <div class="mb-12 sm:mb-14 md:mb-16">
            <div class="flex items-center gap-3 sm:gap-4 mb-3 sm:mb-4">
              <span class="text-3xl sm:text-4xl">{category.emoji}</span>
              <h3 class="text-2xl sm:text-3xl md:text-4xl font-bold text-warm-900">
                {categoryName === "Reposteria y Snacks" ? "Repostería y Snacks" : categoryName}
              </h3>
            </div>
            
            <p class="text-warm-600 text-base sm:text-lg leading-relaxed max-w-3xl">
              {category.description}
            </p>
            
            <div class="mt-3 sm:mt-4 pt-3 sm:pt-4 border-t border-chaud-200">
              <span class="inline-block text-xs sm:text-sm text-chaud-600 font-semibold bg-chaud-50 px-3 py-1.5 rounded-full border border-chaud-200">
                {category.keywords}
              </span>
            </div>
          </div>

          <!-- Products Grid for Category -->
          <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-4 sm:gap-6 lg:gap-8">
            {categoryProducts.map((product) => (
              <div 
                class="bg-white rounded-2xl sm:rounded-3xl shadow-md hover:shadow-xl transition-all duration-300 hover:-translate-y-1 border border-chaud-100 hover:border-chaud-300 overflow-hidden group"
              >
                <!-- Product Image -->
                <div class="relative overflow-hidden aspect-square bg-chaud-50">
                  <img 
                    src={getCloudinaryUrl(product.image, { width: 400 })}
                    srcset={getResponsiveSrcSet(product.image, [320, 400, 640])}
                    sizes="(max-width: 640px) 320px, (max-width: 1024px) 400px, 640px"
                    alt={`${product.name} - ${categoryName} artesanal en Ciudad Serdán, Puebla - Chaud & Glace`}
                    class="w-full h-full object-contain p-3 sm:p-4 group-hover:scale-110 transition-transform duration-700"
                    loading="lazy"
                    decoding="async"
                  />
                  
                  <!-- Price Badge -->
                  <div class="absolute top-3 right-3 sm:top-4 sm:right-4 bg-chaud-600 text-white px-3 py-1.5 sm:px-4 sm:py-2 rounded-full font-bold text-sm sm:text-base shadow-lg">
                    {product.price}
                  </div>
                </div>

                <!-- Product Info -->
                <div class="p-4 sm:p-5 lg:p-6">
                  <h4 class="text-lg sm:text-xl font-bold text-warm-900 mb-2 leading-snug">
                    {product.name}
                  </h4>
                  
                  <p class="text-sm sm:text-base text-warm-600 mb-4 leading-relaxed line-clamp-3">
                    {product.description}
                  </p>

                  {product.size && (
                    <div class="inline-flex items-center gap-1.5 text-xs sm:text-sm font-semibold text-chaud-600 bg-chaud-50 px-2.5 py-1.5 sm:px-3 rounded-full border border-chaud-200 mb-4">
                      <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M7 21a4 4 0 01-4-4V5a2 2 0 012 2h4a2 2 0 012 2v12a4 4 0 01-4 4zm0 0h12a2 2 0 002-2v-4a2 2 0 00-2-2h-2.343M11 7.343l1.657-1.657a2 2 0 012.828 0l2.829 2.829a2 2 0 010 2.828l-8.486 8.485M7 17h.01"></path>
                      </svg>
                      {product.size}
                    </div>
                  )}

                  <div class="mt-4">
                    <AddToCartButton
                      client:idle
                      id={product.id}
                      name={product.name}
                      price={product.numericPrice}
                      image={product.image}
                      size={product.size}
                    />
                  </div>
                </div>
              </div>
            ))}
          </div>

          {categoryProducts.length < 5 && (
            <div class="mt-10 sm:mt-12 p-6 sm:p-8 bg-chaud-50 rounded-2xl border-2 border-dashed border-chaud-300 text-center">
              <p class="text-warm-600 text-sm sm:text-base">
                Tenemos más opciones en esta categoría. Contáctanos para conocer nuestras últimas creaciones.
              </p>
            </div>
          )}

          <!-- Category Divider -->
          {categoryProducts.length > 0 && (
            <div class="mt-16 sm:mt-20 md:mt-24 pt-16 sm:pt-20 md:pt-24 border-t-2 border-chaud-200"></div>
          )}
        </div>
      );
    })}

    <!-- Why Choose Us Section -->
    <div class="mt-20 sm:mt-24 md:mt-32 pt-16 sm:pt-20 md:pt-24 border-t-2 border-chaud-200">
      <div class="grid grid-cols-1 md:grid-cols-3 gap-8 sm:gap-10 lg:gap-12 max-w-5xl mx-auto">
        <div class="text-center">
          <div class="text-4xl sm:text-5xl mb-4 sm:mb-6">🥇</div>
          <h4 class="text-xl sm:text-2xl font-bold text-warm-900 mb-3 sm:mb-4">Helados Gourmet</h4>
          <p class="text-warm-600 text-base sm:text-lg leading-relaxed">
            Nuestros helados artesanales se elaboran con técnicas tradicionales y ingredientes premium importados.
          </p>
        </div>
        
        <div class="text-center">
          <div class="text-4xl sm:text-5xl mb-4 sm:mb-6">👨‍⚖️</div>
          <h4 class="text-xl sm:text-2xl font-bold text-warm-900 mb-3 sm:mb-4">Recetas Artesanales</h4>
          <p class="text-warm-600 text-base sm:text-lg leading-relaxed">
            Cada producto en Chaud & Glace es una creación propia hecha con dedicación y amor.
          </p>
        </div>
        
        <div class="text-center">
          <div class="text-4xl sm:text-5xl mb-4 sm:mb-6">🌿</div>
          <h4 class="text-xl sm:text-2xl font-bold text-warm-900 mb-3 sm:mb-4">Sin Conservantes</h4>
          <p class="text-warm-600 text-base sm:text-lg leading-relaxed">
            Utilizamos solo ingredientes naturales. Sin conservantes, sin colorantes artificiales.
          </p>
        </div>
      </div>
    </div>

    <!-- CTA Section -->
    <div class="mt-16 sm:mt-20 md:mt-24 bg-linear-to-r from-chaud-600 to-chaud-700 rounded-3xl p-8 sm:p-10 lg:p-12 text-white text-center">
      <h3 class="text-2xl sm:text-3xl md:text-4xl font-bold mb-3 sm:mb-4">¿Listo para Probar lo Mejor?</h3>
      <p class="text-base sm:text-lg text-chaud-100 mb-6 sm:mb-8 max-w-2xl mx-auto">
        Visítanos en Ciudad Serdán, Puebla o contáctanos para hacer tu pedido por WhatsApp.
      </p>
      
      <div class="flex flex-col sm:flex-row gap-4 justify-center flex-wrap">
        <a 
          href="https://wa.me/522451051911"
          target="_blank"
          rel="noopener noreferrer"
          class="inline-flex items-center justify-center gap-2 px-8 py-4 bg-white text-chaud-600 rounded-full font-bold text-lg hover:bg-chaud-50 hover:shadow-2xl transition-all duration-300 hover:scale-105"
        >
          <svg class="w-6 h-6" fill="currentColor" viewBox="0 0 24 24">
            <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.272-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.67-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.076 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421-7.403h-.004a9.87 9.87 0 00-9.746 13.925c.17.32.56.562.931.62l2.596.397c.416.063.793-.335.66-.736-.31-.918-.696-1.76-1.142-2.538-.137-.231-.02-.521.189-.642 1.233-.806 2.625-1.288 4.108-1.39.193-.014.383.002.572.021.188.018.376.03.564.04 1.393.088 2.734.534 3.856 1.262.21.136.389.25.629.25.21 0 .41-.087.568-.247 1.04-1.065 1.886-2.354 2.42-3.799.152-.439-.114-.9-.566-.962-.452-.063-2.607-.4-2.607-.4m5.107-4.78c-1.264-1.265-2.92-1.961-4.696-1.961-3.653 0-6.626 2.973-6.626 6.626 0 1.476.516 2.927 1.47 4.113.135.168.336.265.55.265.113 0 .226-.027.334-.083 1.202-.651 2.337-1.504 3.291-2.525.299-.309.284-.8-.035-1.093-1.06-1.06-1.647-2.47-1.647-3.965 0-3.086 2.51-5.596 5.596-5.596 1.475 0 2.885.587 3.945 1.647.31.31.784.325 1.093.036 1.02-.954 1.872-2.089 2.522-3.291.056-.108.084-.221.084-.334 0-.214-.097-.415-.265-.55z" />
          </svg>
          Ordenar por WhatsApp
        </a>
        <a 
          href="#contacto"
          class="inline-flex items-center justify-center gap-2 px-8 py-4 bg-chaud-500 text-white rounded-full font-bold text-lg hover:bg-white hover:text-chaud-600 hover:shadow-2xl transition-all duration-300 hover:scale-105"
        >
          <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" />
          </svg>
          Contáctanos
        </a>
      </div>
    </div>
  </div>
</section>

<style>
  .line-clamp-3 {
    display: -webkit-box;
    -webkit-line-clamp: 3;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }
</style>
