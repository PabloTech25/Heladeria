---
import CartIcon from './CartIcon.svelte';

interface Props {
  currentPage?: 'home' | 'blog';
}

const { currentPage = 'home' } = Astro.props;

// Helper function to get correct link based on current page
const getLink = (anchor: string) => {
  if (currentPage === 'blog') {
    return `/${anchor}`;
  }
  return anchor;
};
---

<header
    class="fixed top-0 left-0 right-0 z-50 bg-white/95 backdrop-blur-lg shadow-sm border-b border-chaud-100"
>
    <nav class="container mx-auto px-4 py-2 sm:py-3">
        <div class="flex items-center justify-between">
            <!-- Logo and Brand -->
            <a href={getLink("#inicio")} class="flex items-center gap-2 sm:gap-3 lg:gap-4 group transition-transform hover:scale-105 duration-300">
                <img
                    src="/logo/LogoChaud.png"
                    alt="Chaud & Glace Logo"
                    class="h-12 w-12 sm:h-16 sm:w-16 md:h-20 md:w-20 lg:h-24 lg:w-24 object-contain transition-transform group-hover:rotate-6 duration-300"
                />
                <div class="flex flex-col">
                    <span class="text-lg sm:text-xl md:text-2xl lg:text-3xl font-bold text-warm-900 leading-tight">
                        Chaud &amp; Glace
                    </span>
                    <span class="hidden sm:block text-xs md:text-sm text-chaud-600 font-medium">
                        Cafe con encanto
                    </span>
                </div>
            </a>

            <!-- Desktop Navigation -->
            <ul class="hidden md:flex items-center gap-8">
                <li>
                    <a
                        href={getLink("#inicio")}
                        class="text-warm-700 hover:text-chaud-600 transition-colors font-medium text-sm uppercase tracking-wide"
                    >
                        Inicio
                    </a>
                </li>
                <li>
                    <a
                        href={getLink("#sobre-nosotros")}
                        class="text-warm-700 hover:text-chaud-600 transition-colors font-medium text-sm uppercase tracking-wide"
                    >
                        Nosotros
                    </a>
                </li>
                <li>
                    <a
                        href={getLink("#menu")}
                        class="text-warm-700 hover:text-chaud-600 transition-colors font-medium text-sm uppercase tracking-wide"
                    >
                        Menú
                    </a>
                </li>
                <li>
                    <a
                        href="/blog"
                        class="text-warm-700 hover:text-chaud-600 transition-colors font-medium text-sm uppercase tracking-wide"
                    >
                        Blog
                    </a>
                </li>
                <li>
                    <a
                        href={getLink("#contacto")}
                        class="text-warm-700 hover:text-chaud-600 transition-colors font-medium text-sm uppercase tracking-wide"
                    >
                        Contacto
                    </a>
                </li>
            </ul>

            <!-- Action Buttons -->
            <div class="flex items-center gap-3">
                <!-- Cart Icon -->
                <CartIcon client:load />

                <!-- Call Button -->
                <a
                    href="tel:2454522978"
                    class="hidden md:flex items-center gap-2 bg-chaud-600 hover:bg-chaud-700 text-white px-6 py-3 rounded-full font-semibold shadow-md hover:shadow-lg transition-all duration-300"
                >
                    <svg
                        class="w-5 h-5"
                        fill="none"
                        stroke="currentColor"
                        viewBox="0 0 24 24"
                    >
                        <path
                            stroke-linecap="round"
                            stroke-linejoin="round"
                            stroke-width="2"
                            d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"
                        ></path>
                    </svg>
                    Llámanos
                </a>

                <!-- Mobile Menu Button -->
                <button
                    id="mobile-menu-button"
                    class="md:hidden text-warm-700 hover:text-chaud-600 transition-colors p-2"
                    aria-label="Toggle menu"
                >
                    <svg
                        class="w-6 h-6"
                        fill="none"
                        stroke="currentColor"
                        viewBox="0 0 24 24"
                    >
                        <path
                            stroke-linecap="round"
                            stroke-linejoin="round"
                            stroke-width="2"
                            d="M4 6h16M4 12h16M4 18h16"></path>
                    </svg>
                </button>
            </div>
        </div>

        <!-- Mobile Navigation -->
        <div
            id="mobile-menu"
            class="hidden md:hidden mt-4 pb-4 border-t border-chaud-100 pt-4"
        >
            <ul class="flex flex-col gap-4">
                <li>
                    <a
                        href={getLink("#inicio")}
                        class="block text-warm-700 hover:text-chaud-600 transition-colors font-medium py-2"
                    >
                        Inicio
                    </a>
                </li>
                <li>
                    <a
                        href={getLink("#sobre-nosotros")}
                        class="block text-warm-700 hover:text-chaud-600 transition-colors font-medium py-2"
                    >
                        Sobre Nosotros
                    </a>
                </li>
                <li>
                    <a
                        href={getLink("#menu")}
                        class="block text-warm-700 hover:text-chaud-600 transition-colors font-medium py-2"
                    >
                        Menú
                    </a>
                </li>
                <li>
                    <a
                        href="/blog"
                        class="block text-warm-700 hover:text-chaud-600 transition-colors font-medium py-2"
                    >
                        Blog
                    </a>
                </li>
                <li>
                    <a
                        href={getLink("#contacto")}
                        class="block text-warm-700 hover:text-chaud-600 transition-colors font-medium py-2"
                    >
                        Contacto
                    </a>
                </li>
                <li>
                    <a
                        href="tel:2454522978"
                        class="flex items-center justify-center gap-2 bg-chaud-600 hover:bg-chaud-700 text-white px-6 py-3 rounded-full font-semibold shadow-md transition-all duration-300"
                    >
                        <svg
                            class="w-5 h-5"
                            fill="none"
                            stroke="currentColor"
                            viewBox="0 0 24 24"
                        >
                            <path
                                stroke-linecap="round"
                                stroke-linejoin="round"
                                stroke-width="2"
                                d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"
                            ></path>
                        </svg>
                        Llámanos
                    </a>
                </li>
            </ul>
        </div>
    </nav>
</header>

<script>
    // Mobile menu toggle
    const mobileMenuButton = document.getElementById("mobile-menu-button");
    const mobileMenu = document.getElementById("mobile-menu");

    mobileMenuButton?.addEventListener("click", () => {
        mobileMenu?.classList.toggle("hidden");
    });

    // Smooth scrolling for anchor links with header offset (fixed header)
    // Only for same-page anchors (e.g., #menu), not for cross-page navigation (e.g., /#menu)
    document.querySelectorAll('a[href^="#"]').forEach((anchor) => {
        anchor.addEventListener("click", (e) => {
            const href = anchor.getAttribute("href");
            if (!href || href === "#") return;
            const target = document.querySelector(href);
            if (!target) return;
            e.preventDefault();

            const headerEl = document.querySelector('header');
            const headerHeight = headerEl ? headerEl.offsetHeight : 0;

            const targetY = target.getBoundingClientRect().top + window.pageYOffset - headerHeight - 12;
            window.scrollTo({ top: targetY, behavior: 'smooth' });

            // Close mobile menu after clicking
            mobileMenu?.classList.add("hidden");
        });
    });
</script>
