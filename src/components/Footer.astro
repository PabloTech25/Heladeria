---
// Footer component for Chaud & Glace
const currentYear = new Date().getFullYear();
---

<footer class="bg-rose-100 border-t border-rose-200/60">
    <div class="container mx-auto px-4 sm:px-6 py-8 sm:py-10">
        <div class="max-w-6xl mx-auto">
            <!-- Brand & Content Grid -->
            <div class="grid grid-cols-1 lg:grid-cols-[auto_1fr] gap-6 sm:gap-8 items-start mb-6">
                <!-- Brand Section -->
                <div class="text-center lg:text-left">
                    <h2 class="text-2xl sm:text-3xl font-bold text-warm-900 mb-1">
                        Chaud &amp; Glace
                    </h2>
                    <p class="text-chaud-600 font-medium text-sm mb-2">
                        Cafe con encanto
                    </p>
                    <p class="text-warm-700 text-xs sm:text-sm leading-relaxed">
                        Donde el sabor y la calidez existen en un mismo lugar
                    </p>
                </div>

                <!-- Social Links -->
                <div class="text-center lg:text-right lg:flex lg:justify-end lg:items-start">
                    <div>
                        <p class="text-xs font-semibold text-warm-600 uppercase tracking-wider mb-3">
                            Síguenos
                        </p>
                        <div class="flex flex-wrap justify-center lg:justify-end items-center gap-2">
                            <a
                                href="https://www.facebook.com/share/1ApReivZHt/?mibextid=wwXIfr"
                                target="_blank"
                                rel="noopener noreferrer"
                                class="px-4 py-1.5 bg-white border border-rose-200 rounded-full text-warm-800 hover:bg-chaud-600 hover:text-white hover:border-chaud-600 transition-all duration-200 text-xs sm:text-sm font-medium"
                                aria-label="Facebook"
                            >
                                Facebook
                            </a>
                            <a
                                href="https://www.instagram.com/chaud.and.glace?igsh=NHQ0dGF3bnpibGx0"
                                target="_blank"
                                rel="noopener noreferrer"
                                class="px-4 py-1.5 bg-white border border-rose-200 rounded-full text-warm-800 hover:bg-chaud-600 hover:text-white hover:border-chaud-600 transition-all duration-200 text-xs sm:text-sm font-medium"
                                aria-label="Instagram"
                            >
                                Instagram
                            </a>
                        </div>
                    </div>
                </div>
            </div>

            <!-- Copyright -->
            <div class="border-t border-rose-200/50 pt-4">
                <p class="text-center text-warm-600 text-xs">
                    © {currentYear} Chaud &amp; Glace • Todos los derechos reservados
                </p>
            </div>
        </div>
    </div>
</footer>
